# ── Supabase ─────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── Execution mode ───────────────────────────────────────
# Set to "false" to enable live trading (NOT implemented yet — keep "true")
PAPER_MODE=true
BASKET_INITIAL_CAPITAL=1000
SCALPER_INITIAL_CAPITAL=1000

